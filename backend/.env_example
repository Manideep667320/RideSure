# Server Configuration
PORT=5000

# MongoDB Connection String (Replace with your Atlas URI)
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/ridesure

# JWT Secret for Authentication
JWT_SECRET=your_jwt_secret_here

# Supervity AI Integration (Optional for full claim logic)
SUPERVITY_API_TOKEN=your_supervity_token_here
SUPERVITY_WORKFLOW_ID=your_supervity_workflow_id_here
